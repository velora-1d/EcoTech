DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecotech"
NEXT_PUBLIC_APP_URL="https://ecotech.santrix.my.id"

# Ganti dengan string random panjang di production
SESSION_SECRET="ganti-ini-dengan-string-random-panjang"

# Akun admin via env — bekerja TANPA database
ADMIN_EMAIL="admin@ecotech.id"
ADMIN_PASSWORD="admin123"

# Konfigurasi OpenAI-Compatible API untuk Pemindai Sampah
AI_API_KEY="isi_api_key_anda_di_sini"
AI_API_BASE="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"

# STORAGE (Cloudflare R2 / RustFS S3-Compatible)
R2_ACCOUNT_ID="isi_account_id_anda"
R2_ACCESS_KEY_ID="isi_access_key_id_anda"
R2_SECRET_ACCESS_KEY="isi_secret_access_key_anda"
R2_BUCKET_NAME="isi_bucket_name_anda"
R2_REGION="auto"
R2_ENDPOINT="https://storage.santrix.my.id"
R2_PUBLIC_URL="https://storage.santrix.my.id"


